#!/bin/zsh

_ymt_mog_usage() {
  cat <<EOF
mog opens markdown files with mo using the current git repository name as --target.

Usage:
    mog [files...]    open files in mo with --target=<repo-name>

Options:
    --help, -h        print help

Notes:
    Must be run inside a git repository. The target name is derived from
    the basename of the repository top-level directory.

Dependencies:
    mo
    git
EOF
}

_ymt_mog() {
  if ! command -v mo >/dev/null 2>&1; then
    echo "Error: mo is not installed" >&2
    return 1
  fi

  local repo_root
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null)
  if [[ -z "$repo_root" ]]; then
    echo "Error: not inside a git repository" >&2
    return 1
  fi

  local target=${repo_root:t}
  mo --target="$target" "$@"
}

case ${1} in
  -h|--help)
    _ymt_mog_usage
  ;;

  *)
    _ymt_mog "$@"
  ;;
esac

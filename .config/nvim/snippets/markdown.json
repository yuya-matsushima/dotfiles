{
  "Collapsible section": {
    "prefix": ["details", "fold"],
    "body": [
      "<details>",
      "<summary>${1:summary}</summary>",
      "",
      "$0",
      "",
      "</details>"
    ],
    "description": "HTML 折りたたみセクション"
  },
  "Note callout": {
    "prefix": ["callout-note", "alert-note", "note"],
    "body": [
      "> [!NOTE]",
      "> $0"
    ],
    "description": "GitHub/Obsidian: 補足情報"
  },
